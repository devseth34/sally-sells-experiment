# ============================================================================
# Sally Sells — .env.example
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the real secrets. The real .env is
# gitignored. Every variable used anywhere in the backend or voice agent is
# listed here — if a new one is introduced, add it to this file too.
# ============================================================================

# ---------------------------------------------------------------------------
# Core infrastructure
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/sally_sells
SKIP_SCHEMA_CHECK=false
JWT_SECRET_KEY=change-me-to-a-long-random-string
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# LLM providers (Phase 1A/1B brain — DO NOT rotate without a fresh CDS run)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Stripe (paid workshop checkout)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PAYMENT_LINK=

# ---------------------------------------------------------------------------
# TidyCal (free workshop fallback)
# ---------------------------------------------------------------------------
TIDYCAL_PATH=

# ---------------------------------------------------------------------------
# Twilio SMS (Phase 1B follow-up)
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ---------------------------------------------------------------------------
# Google Sheets webhook (experiment logging)
# ---------------------------------------------------------------------------
GOOGLE_SHEETS_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Gmail escalation (hot-lead alerts)
# ---------------------------------------------------------------------------
GMAIL_USER=
GMAIL_APP_PASSWORD=
ESCALATION_EMAIL=

# ---------------------------------------------------------------------------
# Experiment tuning
# ---------------------------------------------------------------------------
EXPERIMENT_LINK_TURN_THRESHOLD=10
# Invitation URL override — defaults in app/invitation.py if unset
# INVITATION_URL=

# ============================================================================
# Phase 2: Voice agent (new)
# ============================================================================

# ---------------------------------------------------------------------------
# LiveKit (WebRTC room hosting)
# ---------------------------------------------------------------------------
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ---------------------------------------------------------------------------
# Voice providers
# ---------------------------------------------------------------------------
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=

# ---------------------------------------------------------------------------
# Voice cost caps & concurrency (Addendum §B13)
# ---------------------------------------------------------------------------
MAX_CONCURRENT_CALLS=3
DAILY_SPEND_CAP_USD=25
HOURLY_CALL_CAP=15

# ---------------------------------------------------------------------------
# Voice channel kill switch (Addendum §B14)
# Flip to `false` to force-disable the voice endpoint and redirect callers
# to the text experiment.
# ---------------------------------------------------------------------------
VOICE_CHANNEL_ENABLED=true
