# ---------------------------------------------------------------------------
# Voice cost caps & concurrency (Addendum §B13)
# ---------------------------------------------------------------------------
MAX_CONCURRENT_CALLS=3
DAILY_SPEND_CAP_USD=25
HOURLY_CALL_CAP=15

# ---------------------------------------------------------------------------
# Voice channel kill switch (Addendum §B14)
# Flip to ⁠ false ⁠ to force-disable the voice endpoint and redirect callers
# to the text experiment.
# ---------------------------------------------------------------------------
VOICE_CHANNEL_ENABLED=true

# ---------------------------------------------------------------------------
# Voice tab persistence (Phase 1 — new)
# voice_main.py is a separate FastAPI process (port 8001 locally, separate
# Railway service in production). Both the voice agent (Fly.io) and the
# frontend (Vite / Vercel) call it.
# ---------------------------------------------------------------------------

# Shared secret: voice agent sets this in its POST /voice/persist header.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
VOICE_PERSIST_TOKEN=

# URL the voice agent uses to POST sessions to voice_main.
# Local dev: http://localhost:8001/voice/persist
# Production: https://<your-railway-voice-service>.up.railway.app/voice/persist
VOICE_PERSIST_URL=http://localhost:8001/voice/persist

# Port for voice_main.py (default 8001)
VOICE_PORT=8001

# ---------------------------------------------------------------------------
# Frontend (Vite) — add to frontend/.env.local for local dev
# ---------------------------------------------------------------------------
# VITE_VOICE_API_URL=http://localhost:8001
# For production Vercel, set VITE_VOICE_API_URL to the Railway service URL.
