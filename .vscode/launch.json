{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI: backend (uvicorn on :8000)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "justMyCode": false,
      "console": "integratedTerminal"
    },
    {
      "name": "Voice agent: python -m voice_agent.agent",
      "type": "debugpy",
      "request": "launch",
      "module": "voice_agent.agent",
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "justMyCode": false,
      "console": "integratedTerminal"
    },
    {
      "name": "Vite: frontend dev server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "All services (backend + voice + frontend)",
      "configurations": [
        "FastAPI: backend (uvicorn on :8000)",
        "Voice agent: python -m voice_agent.agent",
        "Vite: frontend dev server"
      ],
      "stopAll": true
    }
  ]
}
