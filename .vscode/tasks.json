{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend: uvicorn",
      "type": "shell",
      "command": "uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "group": "dev-servers",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "voice-agent: python -m voice_agent.agent",
      "type": "shell",
      "command": "python -m voice_agent.agent",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "group": "dev-servers",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "frontend: vite dev",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "group": "dev-servers",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "Start all dev servers",
      "dependsOn": [
        "backend: uvicorn",
        "voice-agent: python -m voice_agent.agent",
        "frontend: vite dev"
      ],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
